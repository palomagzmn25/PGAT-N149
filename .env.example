# ─── Base de Datos ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://notarial_user:notarial_pass@localhost:5432/notarial_db?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-secret-in-production"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_TYPE="local"          # 'local' | 's3'
UPLOAD_DIR="./uploads"
# AWS_S3_BUCKET=""
# AWS_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# ─── OCR ──────────────────────────────────────────────────────────────────────
OCR_PROVIDER="tesseract"      # 'tesseract' | 'azure' | 'claude' | 'google'
AZURE_OCR_ENDPOINT=""
AZURE_OCR_KEY=""
ANTHROPIC_API_KEY=""
# GOOGLE_VISION_CREDENTIALS=""

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3001

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
